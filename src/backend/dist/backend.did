type ActivityType = 
 variant {
   callScheduled;
   commentAdded;
   documentShared;
   invoiceGenerated;
   noteAdded;
   proposalUploaded;
   quickCall;
   quickEmail;
   quickMeeting;
   statusChange;
   whatsappMessage;
 };
type Activity = 
 record {
   action: text;
   details: text;
   id: text;
   internId: text;
   performedBy: text;
   timestamp: int;
 };
service : {
  addClientActivity: (clientId: text, activityType: ActivityType,
   description: text, metadata: opt text) ->
   (variant {
      err: text;
      ok: ClientActivity;
    });
  addClientComment: (clientId: text, content: text, parentId: opt text) ->
   (variant {
      err: text;
      ok: ClientComment;
    });
  addContact: (clientId: text, contact: ContactPerson) ->
   (variant {
      err: text;
      ok: Client;
    });
  addDocumentVersion: (sessionToken: text, docId: text, versionLabel: 
   text, notes: text) -> (variant {
                            err: text;
                            ok: DocumentRecord;
                          });
  addNoteComment: (sessionToken: text, noteId: text, content: text, status:
   text) -> (variant {
               err: text;
               ok: DailyNote;
             });
  addPerformance: (sessionToken: text, payload: CreatePerformancePayload) ->
   (variant {
      err: text;
      ok: Performance;
    });
  addProjectMilestone: (sessionToken: text, internId: text, projId: text,
   milestoneName: text) -> (variant {
                              err: text;
                              ok: ProjectParticipation;
                            });
  addTimelineMilestone: (sessionToken: text, internId: text, title: text,
   description: opt text, milestoneType: text) ->
   (variant {
      err: text;
      ok: TimelineMilestone;
    });
  approveRequest: (sessionToken: text, requestId: text, notes: opt text) ->
   (variant {
      err: text;
      ok: ApprovalRequest;
    });
  archiveDocument: (sessionToken: text, docId: text) ->
   (variant {
      err: text;
      ok: bool;
    });
  captureWonLostReason: (clientId: text, reason: text) ->
   (variant {
      err: text;
      ok: Client;
    });
  computeCompositeScore: (sessionToken: text, internId: text) ->
   (variant {
      err: text;
      ok: CompositePerformanceScore;
    });
  createAnnouncement: (payload:
   record {
     content: text;
     createdBy: text;
     title: text;
   }) -> (variant {
            err: text;
            ok: Announcement;
          });
  createAnnouncementV2: (sessionToken: text, title: text, body: text,
   targetSpaces: vec text, expiresAt: opt int) ->
   (variant {
      err: text;
      ok: Announcement;
    });
  createApprovalRequest: (sessionToken: text, actionType: text, resourceType:
   text, resourceId: text, payload: text) ->
   (variant {
      err: text;
      ok: ApprovalRequest;
    });
  createChannel: (sessionToken: text, name: text, spaceId: text, memberIds:
   vec text) -> (variant {
                   err: text;
                   ok: Channel;
                 });
  createClient: (req: CreateClientRequest) ->
   (variant {
      err: text;
      ok: Client;
    });
  createDailyNote: (sessionToken: text, payload: CreateDailyNotePayload) ->
   (variant {
      err: text;
      ok: DailyNote;
    });
  createDocumentRecord: (sessionToken: text, internId: text, category: 
   text, docType: text, fileName: text, versionLabel: text, notes: text) ->
   (variant {
      err: text;
      ok: DocumentRecord;
    });
  createIntern: (sessionToken: text, payload: CreateInternPayload) ->
   (variant {
      err: text;
      ok: Intern;
    });
  createInternAudited: (sessionToken: text, payload: CreateInternPayload) ->
   (variant {
      err: text;
      ok: Intern;
    });
  createInvoice: (clientId: text, lineItems: vec InvoiceLineItem, tax:
   float64, notes: opt text) -> (variant {
                                   err: text;
                                   ok: Invoice;
                                 });
  createNotification: (payload:
   record {
     message: text;
     notificationType: NotificationType;
     priority: NotificationPriority;
     relatedId: opt text;
     title: text;
     userId: text;
   }) -> (variant {
            err: text;
            ok: Notification;
          });
  createProjectParticipation: (sessionToken: text, internId: text,
   projectName: text, role: text, startDate: text, deliverables: vec text) ->
   (variant {
      err: text;
      ok: ProjectParticipation;
    });
  createSubmission: (sessionToken: text, payload: CreateSubmissionPayload) ->
   (variant {
      err: text;
      ok: WorkSubmission;
    });
  createTask: (sessionToken: text, payload: CreateTaskPayload) ->
   (variant {
      err: text;
      ok: Task;
    });
  createUser: (sessionToken: text, username: text, password: text, roleText:
