type WorkspaceData = 
 record {
   channelMessages: vec ChannelMessage;
   directMessages: vec DirectMessage;
   meetings: vec Meeting;
   milestones: vec TimelineMilestone;
   notes: vec DailyNote;
   submissions: vec WorkSubmission;
   tasks: vec Task;
 };
type WorkflowExecution = 
 record {
   errorMessage: opt text;
   id: text;
