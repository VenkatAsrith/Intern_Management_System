  getAllTasks: (sessionToken: text) -> (vec Task) query;
  getAnalyticsDashboard: () -> (AnalyticsData) query;
  getAnnouncementsBySpace: (sessionToken: text, space: opt text) ->
   (variant {
      err: text;
      ok: vec Announcement;
