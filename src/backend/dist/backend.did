  getClientInvoices: (clientId: text) -> (vec Invoice) query;
  getCompositeScore: (internId: text) ->
   (opt CompositePerformanceScore) query;
  getDailyNotesByIntern: (sessionToken: text, internId: text) ->
   (vec DailyNote) query;
  getDashboardSnapshot: (sessionToken: text) ->
