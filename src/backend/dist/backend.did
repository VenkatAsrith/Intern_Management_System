   status: text;
 };
type ProjectMilestone = 
 record {
   completedAt: opt int;
   id: text;
   name: text;
   status: text;
 };
type PriorityLevel = 
 variant {
   high;
   low;
   medium;
   urgent;
 };
type Performance = 
 record {
   adminNotes: text;
   attendanceScore: float64;
   communicationScore: float64;
   createdAt: int;
   id: text;
   initiativeScore: float64;
   internId: text;
   month: nat;
   overallScore: float64;
   taskScore: float64;
   year: nat;
 };
type PaymentStatus = 
 variant {
   cancelled;
   overdue;
   paid;
   pending;
 };
type NotificationType = 
 variant {
   announcement;
   announcementPosted;
   approvalRequestCreated;
   attendanceAnomaly;
   dealClosedWon;
   dealSLABreached;
   followUpOverdue;
   healthScoreLow;
   internDocumentSent;
   invoiceDue;
   invoiceOverdue;
   leaveApproved;
   leaveRejected;
   newClientAssigned;
   overdueFollowUp;
   proposalExpiring;
   proposalExpiringUrgent;
   stageChanged;
   staleDeal;
   taskAssigned;
   taskOverdue;
 };
type NotificationPriority = 
 variant {
   critical;
   high;
   low;
   medium;
 };
type NotificationPreference = 
 record {
   digestEnabled: bool;
   digestFrequency: variant {
                      daily;
                      hourly;
                      immediate;
                    };
