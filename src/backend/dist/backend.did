 };
type StatusHistoryEntry = 
 record {
   adminName: text;
   note: text;
   status: ClientStatus;
   timestamp: int;
 };
type Status = 
 variant {
   Active;
   Completed;
   OnHold;
 };
type Space = 
 variant {
   Learning;
   Marketing;
   Org;
 };
type SlaStatus = 
 variant {
   breached;
   notBreached;
 };
type Role = 
 variant {
   admin;
   finance;
   hr;
   manager;
   marketing;
   operations;
   sales;
   superAdmin;
   viewer;
 };
type RepScorecard = 
