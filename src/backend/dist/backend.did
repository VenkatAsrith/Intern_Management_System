   (variant {
      err: text;
      ok: UserAccount;
    });
  deleteAnnouncement: (id: text) -> (variant {
                                       err: text;
                                       ok;
                                     });
  deleteAnnouncementById: (sessionToken: text, announcementId: text) ->
